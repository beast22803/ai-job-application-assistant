# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "openrouter" to use cloud models, or "ollama" to use a local instance.
PROVIDER=openrouter

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# ── Ollama (local) ───────────────────────────────────────────────────────────
# Default base URL when Ollama is running locally
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Agent Behaviour ───────────────────────────────────────────────────────────
# How many self-improvement iterations to run before returning final output
MAX_ITERATIONS=2

# ── Jina Reader (Crawler) ─────────────────────────────────────────────────────
# Optional: Get your key at https://jina.ai/reader/
JINA_API_KEY=
